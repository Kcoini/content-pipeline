NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Phase 1-4: AI 기사 생성 연동
# ANTHROPIC_API_KEY는 서버 코드(Server Action/Route Handler)에서만 사용한다.
# 절대 NEXT_PUBLIC_* 접두사를 붙이거나 client component에 노출하지 않는다.
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic
# true이면 AI 기사 생성을 사용하고, false(기본값)이면 mock generator를 사용한다.
AI_GENERATION_ENABLED=false

# Phase 1-12: 트렌드 기반 자동 테마 추출
# true이면 실제 네이버/다음 API를 사용하고, false(기본값)이면 mock 데이터를 사용한다.
TREND_COLLECTION_ENABLED=false
# Phase 1-13: 테마 키워드 기반 기사 URL 후보 수집
# true이면 실제 네이버/카카오 API를 사용하고, false(기본값)이면 mock 데이터를 사용한다.
ARTICLE_SEARCH_ENABLED=false
# 네이버 검색 API (https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 카카오 REST API (https://developers.kakao.com) — 다음 뉴스 트렌드
KAKAO_REST_API_KEY=